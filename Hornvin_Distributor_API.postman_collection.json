{
	"info": {
		"_postman_id": "8b5a9b7-98b8-464f-a1ae-f85fa01f8d08",
		"name": "Hornvin Distributor Panel API",
		"description": "Production-ready API for Distributor Panel in Automobile Supply Chain.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/api/distributor/dashboard" }
					}
				}
			]
		},
		{
			"name": "Inventory",
			"item": [
				{
					"name": "Get Inventory",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/api/distributor/inventory?lowStock=false" }
					}
				},
				{
					"name": "Update Stock",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"quantity\": 50,\n    \"type\": \"add\",\n    \"note\": \"Restocked from admin\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/distributor/inventory/:id" }
					}
				}
			]
		},
		{
			"name": "Orders",
			"item": [
				{
					"name": "Get Orders",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": { "raw": "{{base_url}}/api/distributor/orders?status=pending" }
					}
				},
				{
					"name": "Update Order Status",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"SHIPPED\",\n    \"note\": \"Packed and handed over to logistics\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/distributor/orders/:id/status" }
					}
				}
			]
		},
		{
			"name": "Logistics",
			"item": [
				{
					"name": "Assign Delivery Agent",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderId\": \"order_id_here\",\n    \"agentId\": \"agent_user_id\",\n    \"estimatedDelivery\": \"2024-05-01\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/distributor/delivery/assign" }
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": { "type": "text/javascript", "exec": [""] }
		},
		{
			"listen": "test",
			"script": { "type": "text/javascript", "exec": [""] }
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:5000" },
		{ "key": "token", "value": "your_supabase_jwt_here" }
	]
}
