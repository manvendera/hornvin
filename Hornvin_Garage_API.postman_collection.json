{
	"info": {
		"_postman_id": "b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e",
		"name": "Hornvin Garage B2B API",
		"description": "Production-ready API for Automobile E-commerce Garage Panel (B2B)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Profile & Staff",
			"item": [
				{
					"name": "Get Garage Profile",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/garage/profile",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"profile"
							]
						}
					}
				},
				{
					"name": "Add Staff",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Mechanic\",\n  \"email\": \"john@garage.com\",\n  \"role\": \"mechanic\",\n  \"specialization\": [\"Engine\", \"Brakes\"],\n  \"salary\": 25000\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/garage/staff",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"staff"
							]
						}
					}
				}
			]
		},
		{
			"name": "B2B Ordering",
			"item": [
				{
					"name": "Search Parts (B2B)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/garage/products?vehicleModel=Swift&category=Engine",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"products"
							],
							"query": [
								{ "key": "vehicleModel", "value": "Swift" },
								{ "key": "category", "value": "Engine" }
							]
						}
					}
				},
				{
					"name": "Place Bulk Order",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": [\n    { \"productId\": \"64f...\", \"quantity\": 10 },\n    { \"productId\": \"64g...\", \"quantity\": 5 }\n  ],\n  \"paymentMethod\": \"upi\",\n  \"useCredit\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/garage/orders",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"orders"
							]
						}
					}
				}
			]
		},
		{
			"name": "Service Management",
			"item": [
				{
					"name": "Register Customer Vehicle",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ownerName\": \"Amit Kumar\",\n  \"ownerPhone\": \"9876543210\",\n  \"registrationNumber\": \"DL3S-AB-1234\",\n  \"make\": \"Maruti\",\n  \"model\": \"Swift\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/garage/vehicles",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"vehicles"
							]
						}
					}
				},
				{
					"name": "Create Service Job",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vehicleId\": \"64v...\",\n  \"serviceType\": \"general_service\",\n  \"scheduledDate\": \"2024-04-26T10:00:00Z\",\n  \"complaints\": [\"Oil leak\", \"Brake noise\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/garage/services",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"services"
							]
						}
					}
				}
			]
		},
		{
			"name": "Inventory & Stock",
			"item": [
				{
					"name": "Get Internal Stock",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/garage/inventory",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"garage",
								"inventory"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your_garage_owner_jwt_token",
			"type": "string"
		}
	]
}
