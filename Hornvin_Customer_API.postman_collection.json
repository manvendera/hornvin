{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d",
		"name": "Hornvin Customer B2C API",
		"description": "Production-ready API for Automobile E-commerce Customer Panel (B2C)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Home Module",
			"item": [
				{
					"name": "Get Home Data",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/customer/home",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"home"
							]
						}
					}
				}
			]
		},
		{
			"name": "Product Catalog",
			"item": [
				{
					"name": "Search & Filter Products",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/customer/products?search=brake pad&category=brakes&priceMin=500&sortBy=popularity",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"products"
							],
							"query": [
								{ "key": "search", "value": "brake pad" },
								{ "key": "category", "value": "brakes" },
								{ "key": "priceMin", "value": "500" },
								{ "key": "sortBy", "value": "popularity" }
							]
						}
					}
				},
				{
					"name": "Get Product Details",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/customer/products/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"products",
								":id"
							],
							"variable": [
								{ "key": "id", "value": "product_slug_or_id" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Cart Management",
			"item": [
				{
					"name": "Get Cart",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/customer/cart",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"cart"
							]
						}
					}
				},
				{
					"name": "Add to Cart",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"64f...\",\n  \"quantity\": 2\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customer/cart",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"cart"
							]
						}
					}
				},
				{
					"name": "Update Item Quantity",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"quantity\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customer/cart/:productId",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"cart",
								":productId"
							],
							"variable": [
								{ "key": "productId", "value": "ID" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Order & Checkout",
			"item": [
				{
					"name": "Checkout (Place Order)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"addressId\": \"64f...\",\n  \"paymentMethod\": \"upi\",\n  \"customerNotes\": \"Deliver after 5 PM\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customer/orders/checkout",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"orders",
								"checkout"
							]
						}
					}
				},
				{
					"name": "Get My Orders",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/customer/orders?page=1&status=confirmed",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"orders"
							],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "status", "value": "confirmed" }
							]
						}
					}
				},
				{
					"name": "Track Order",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/customer/orders/:id/tracking",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"orders",
								":id",
								"tracking"
							],
							"variable": [
								{ "key": "id", "value": "OrderID" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Payments",
			"item": [
				{
					"name": "Initiate Payment",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/customer/orders/:id/pay",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"orders",
								":id",
								"pay"
							],
							"variable": [
								{ "key": "id", "value": "OrderID" }
							]
						}
					}
				},
				{
					"name": "Verify Payment Signature",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"razorpay_payment_id\": \"pay_123\",\n  \"razorpay_order_id\": \"order_456\",\n  \"razorpay_signature\": \"sig_789\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customer/orders/:id/verify",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"orders",
								":id",
								"verify"
							],
							"variable": [
								{ "key": "id", "value": "OrderID" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Reviews",
			"item": [
				{
					"name": "Add Review",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"64f...\",\n  \"rating\": 5,\n  \"comment\": \"Excellent quality brake pads!\",\n  \"images\": [\"https://url.com/img1.jpg\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customer/reviews",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customer",
								"reviews"
							]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your_supabase_jwt_token",
			"type": "string"
		}
	]
}
